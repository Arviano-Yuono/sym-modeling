{
  "sgep": {
    "data_dir": "dataset/fem_data/plate_hole_fenics/NH2",
    "loadsteps": [10, 20, 30, 40],
    "fitting_mode": "weak_form",
    "selection_objective": "aicc",
    "active_terms_epsilon": 2,
    "max_elements_per_loadstep": null,
    "noise_level": 0.0,

    "variable_names": ["K1", "K2", "Jm1"],
    "unary_operators": ["square", "sqrt", "log"],
    "binary_operators": ["add", "sub", "mul", "div"],
    "genes_per_model": 4,
    "num_models": 8,
    "generations": 50,
    "max_depth": 2,
    "random_seed": 0,

    "mutation_rate": 0.35,
    "crossover_rate": 0.2,
    "random_fraction": 0.15,
    "elite_model_count": 1,
    "elite_gene_count": 4,

    "regression_method": "stlsq",
    "regression_alpha": 1e-10,
    "sparsity_threshold": 1e-5,
    "refit_active_terms": true,
    "derivative_step": 1e-6,
    "invalid_value_limit": 1e8,
    "duplicate_correlation": 0.999999,

    "output_dir": "output/sgep_weak_form/nh2",
    "save_plots": true,
    "compare_euclid": false,
    "euclid_model": "NH2"
  }
}
